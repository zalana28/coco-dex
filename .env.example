# ─── Coco DEX Environment Variables ───

# Frontend (public, safe to expose via VITE_ prefix)
VITE_PUBLIC_APP_ENV=production
VITE_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# Arc Testnet RPC (used by indexer server-side)
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network

# ─── Server-only secrets ───
# WARNING: Never prefix these with VITE_ — that would expose them to the browser.

# Supabase project URL (not the REST endpoint — just the base URL)
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key — grants full DB access, server-only
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Cron Secret — validates cron/indexer requests
CRON_SECRET=your-random-secret-string

# Circle API health check — server-side only.
# CIRCLE_API_KEY must be server-side only. Do not prefix with VITE_.
# Do not commit real API keys.
CIRCLE_API_KEY=
CIRCLE_BASE_URL=https://api.circle.com
CIRCLE_ENV=testnet

# ─── Backfill configuration ───
# Coco DEX was deployed around block 44170190 on Arc Testnet.
# Do not scan before this block — there are no DEX events.
BACKFILL_FROM_BLOCK=44170190
BACKFILL_TO_BLOCK=
BACKFILL_CHUNK_SIZE=5000

# ─── CocoStablePool V1 deploy variables ───
# Testnet-only. Never commit real private keys.
# COCO_DEPLOYER_PRIVATE_KEY must only live in local env or secure CI secrets.
# Do not use mainnet funds.
COCO_DEPLOYER_PRIVATE_KEY=
COCO_STABLE_TOKEN0=0x3600000000000000000000000000000000000000
COCO_STABLE_TOKEN1=0x89B50855Aa3bE2F677cD6303Cec089B5F319D72a
COCO_STABLE_FEE_BPS=4
COCO_STABLE_A=100
COCO_STABLE_OWNER=

# Optional read-only deployed pool inspection target.
COCO_STABLE_POOL=0x0EA7A79F8864091ac7F2B8643BaA7598a9d05a83

# ─── CocoStablePool V1 initial liquidity variables ───
# Testnet-only. Never commit private keys.
# Amounts should be raw token units. USDC/EURC use 6 decimals.
# Example: 1 USDC = 1000000.
# Start with tiny testnet amounts only.
# Initial liquidity sets the first pool price.
COCO_STABLE_INITIAL_AMOUNT0=
COCO_STABLE_INITIAL_AMOUNT1=
COCO_STABLE_MIN_LP_OUT=
COCO_STABLE_LP_RECIPIENT=
