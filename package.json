{
  "name": "coco-dex",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:mobile": "playwright test --project=\"iPhone 13\" --project=\"Pixel 5\"",
    "typecheck": "tsc --noEmit",
    "debug:xylonet": "npx tsx scripts/debugXylonetQuote.ts",
    "debug:xylonet-pools": "npx tsx scripts/debugXylonetStablePools.ts",
    "debug:xylonet-sim": "npx tsx scripts/debugXylonetSwapSimulation.ts",
    "debug:unitflow": "npx tsx scripts/debugUnitFlowQuote.ts",
    "debug:unitflow-exec": "npx tsx scripts/debugUnitFlowExecution.ts",
    "debug:unitflow-ur": "npx tsx scripts/debugUnitFlowUniversalRouter.ts",
    "discover:synthra": "npx tsx scripts/discoverSynthraContracts.ts",
    "debug:synthra": "npx tsx scripts/debugSynthraQuoteAndSwap.ts",
    "indexer:backfill": "npx tsx scripts/backfillAnalytics.ts",
    "contracts:test": "cd contracts && forge test",
    "contracts:deploy:stable:dry": "cd contracts && forge script script/DeployCocoStablePool.s.sol:DeployCocoStablePool --rpc-url $ARC_TESTNET_RPC_URL",
    "contracts:stable:add-liquidity:dry": "cd contracts && forge script script/AddInitialLiquidityCocoStablePool.s.sol:AddInitialLiquidityCocoStablePool --rpc-url $ARC_TESTNET_RPC_URL"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.14",
    "@wagmi/core": "^3.4.12",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.3.0",
    "viem": "^2.51.0",
    "wagmi": "^3.6.15"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@openzeppelin/contracts": "^5.6.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.8.5",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.7"
  }
}
